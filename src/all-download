#!/bin/bash
set -e

echo "=== Downloading all orgs in parallel ==="

npx tsx src/forpd.ts focs/FORPD &
npx tsx src/smud.ts focs/SMUD &
npx tsx src/sjusd.ts focs/SJUSD &
npx tsx src/smfd.ts focs/SMFD &
npx tsx src/fowd.ts focs/FOWD &
npx tsx src/scoe.ts focs/SCOE &
npx tsx src/lrccd.ts focs/LRCCD &
npx tsx src/sjwd.ts focs/SJWD &

wait
echo "=== All downloads complete ==="

# Fix SCOE: move board minutes files to matching date folders
find focs/SCOE -type f -name "[0-9][0-9].[0-9][0-9].[0-9][0-9] Board Minutes*" | while read file; do
  filename=$(basename "$file")
  if [[ $filename =~ ([0-9]{2})\.([0-9]{2})\.([0-9]{2}) ]]; then
    month=${filename:0:2}
    day=${filename:3:2}
    year=${filename:6:2}
    target_date="20${year}-${month}-${day}"
    target_dir=$(find focs/SCOE -type d -name "${target_date}-*" | head -n 1)
    if [ -n "$target_dir" ]; then
      mv "$file" "$target_dir/"
      echo "Moved $filename to $target_dir"
    else
      echo "No matching directory found for $filename"
    fi
  fi
done

