#!/bin/bash
set -e

AFTER="2024-06"

# Convert PDF files to markdown — all orgs in parallel.
PIDS=()
for ORG in FORPD SMUD SJUSD SMFD FOWD LRCCD SJWD SCOE; do
    src/process "focs/$ORG" "$AFTER" &
    PIDS+=($!)
done

# Wait for all and track failures
FAILED=0
for PID in "${PIDS[@]}"; do
    if ! wait "$PID"; then
        ((FAILED++))
    fi
done

if [[ $FAILED -gt 0 ]]; then
    echo "$FAILED org(s) failed."
    exit 1
fi

echo "All done."
