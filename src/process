#!/bin/bash

# src/process focs/FORPD

# Handle Ctrl+C gracefully
trap 'echo -e "\nInterrupted by user. Exiting..."; exit 1' INT
if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "Usage: $0 <directory> [after_date]"
    echo "Example: $0 focs/SJUSD 2024-06"
    exit 1
fi

DIR="$1"

if [[ ! -d "$DIR" ]]; then
    echo "Error: $DIR is not a directory"
    exit 1
fi

# Derive the docs output directory (focs/ORG -> docs/ORG)
DOCS_DIR="${DIR/focs\//docs\/}"

# Set AFTER to second argument if provided, otherwise default to 2024
AFTER="${2:-2024}"

ALL_FILES=$(find "$DIR" -type f -name "*.pdf" | sort -r)
ALL_COUNT=$(echo "$ALL_FILES" | wc -l | tr -d ' ')

PROCESS_FILES=$(echo "$ALL_FILES" | awk -v after="$DIR/$AFTER" '$0 >= after')
PROCESS_COUNT=$(echo "$PROCESS_FILES" | wc -l | tr -d ' ')

# Filter to only unprocessed PDFs (check for .md in docs/ dir)
TO_PROCESS=()
SKIPPED=0
while IFS= read -r pdf_file; do
    # Map focs path to docs path for the .md file
    md_file="${pdf_file/focs\//docs\/}"
    md_file="${md_file%.pdf}.md"
    if [[ -f "$md_file" ]]; then
        ((SKIPPED++))
    else
        TO_PROCESS+=("$pdf_file")
    fi
done < <(echo "$PROCESS_FILES")

ORG=$(basename "$DIR")
echo "[$ORG] $ALL_COUNT total, $PROCESS_COUNT after $AFTER, $SKIPPED done, ${#TO_PROCESS[@]} to process"

if [[ ${#TO_PROCESS[@]} -eq 0 ]]; then
    exit 0
fi

# Batch all PDFs in a single JVM call, suppress Java warnings
START=$(python3 -c 'import time; print(time.time())')
npx opendataloader-pdf -f markdown --quiet "${TO_PROCESS[@]}" 2>/dev/null
END=$(python3 -c 'import time; print(time.time())')
ELAPSED=$(python3 -c "print(f'{$END - $START:.1f}')")

echo "[$ORG] Done: ${#TO_PROCESS[@]} files in ${ELAPSED}s"

# Move generated .md files from focs/ to docs/
for pdf_file in "${TO_PROCESS[@]}"; do
    md_src="${pdf_file%.pdf}.md"
    if [[ -f "$md_src" ]]; then
        md_dest="${md_src/focs\//docs\/}"
        mkdir -p "$(dirname "$md_dest")"
        mv "$md_src" "$md_dest"
    fi
done

# Also copy any HTML files to docs/ for summarization (e.g., SCOE agendas)
find "$DIR" -type f -name "*.html" | while read -r html_file; do
    html_dest="${html_file/focs\//docs\/}"
    if [[ ! -f "$html_dest" ]]; then
        mkdir -p "$(dirname "$html_dest")"
        cp "$html_file" "$html_dest"
    fi
done
